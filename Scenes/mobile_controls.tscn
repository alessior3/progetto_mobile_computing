[sub_resource type="GDScript" id="GDScript_7fp4u"]
script/source = "extends CanvasLayer

func _ready():
	pass
# Called every frame. 'delta' is the elapsed time since the previous frame.
func _process(delta: float) -> void:
	pass


func _on_menu_button_pressed() -> void:
	# Creiamo un finto evento della tastiera
	var fake_esc = InputEventAction.new()
	
	# Metti qui il nome esatto che hai trovato nella Input Map (es. \"ui_cancel\" o \"pause\")
	fake_esc.action = \"pause\" 
	fake_esc.pressed = true
	
	# Inviamo il comando al gioco!
	Input.parse_input_event(fake_esc)# Replace with function body.
"

